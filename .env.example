# ---- Jarvis configuration ----
# Copy to .env and fill in. Values here are safe defaults for local dev.

# Server
JARVIS_HOST=0.0.0.0
JARVIS_PORT=8765
JARVIS_LOG_LEVEL=INFO
JARVIS_DATA_DIR=./var

# Auth — shared secret between clients and server. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JARVIS_API_KEY=change-me-to-a-long-random-string

# Default LLM provider: ollama | anthropic | openai
JARVIS_LLM_PROVIDER=ollama
JARVIS_LLM_FALLBACK=anthropic

# Ollama (local Gemma / Llama / etc.)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI-compatible (OpenAI, Gemini via OpenAI-compat endpoint, Groq, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# GitHub — personal access token for repo operations
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=

# Claude Code dispatcher — path to the `claude` CLI
CLAUDE_CODE_CLI=claude
CLAUDE_CODE_WORKSPACES=./var/workspaces

# Voice
JARVIS_VOICE_ENABLED=true
JARVIS_WHISPER_MODEL=base
JARVIS_TTS_RATE=180

# CORS — comma-separated origins, or * for any
JARVIS_CORS_ORIGINS=*

# Tool permissions — comma-separated tool names allowed to execute.
# Set to "*" to allow all. Shell execution is off by default.
JARVIS_ALLOWED_TOOLS=filesystem_read,filesystem_write,web_search,web_fetch,github_list_repos,github_get_file,github_create_issue,system_info,notify,claude_code_dispatch
